# Android release signing credentials for Jobpoper.
#
# 1. Copy this file to android-keystore.properties (without ".example")
# 2. Fill in your real keystore credentials below
# 3. NEVER commit android-keystore.properties — it's already in .gitignore
#
# After filling this in, just run `npx expo prebuild --clean` and signing
# is configured automatically. No environment variables needed.

storeFile=jobpoper_key.jks
storePassword=YOUR_KEYSTORE_PASSWORD_HERE
keyAlias=YOUR_KEY_ALIAS_HERE
keyPassword=YOUR_KEY_PASSWORD_HERE
