{
  "expo": {
    "name": "JobPoper",
    "slug": "jobpoper",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jobpoper",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#3B6FF8",
      "resizeMode": "cover"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.jobpoper",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to place the delivery pin and find your address.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We use your location to place the delivery pin and find your address."
      }
    },
    "android": {
      "package": "com.anonymous.Jobpoper",
      "icon": "./assets/images/icon.png",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDx-5zOU35lqenxx6TCR-OkQRj6cHpi5-U"
        }
      },
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#3B6FF8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      ["expo-location"],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3B6FF8",
          "image": "./assets/images/splash.png",
          "resizeMode": "cover",
          "ios": {
            "backgroundColor": "#3B6FF8",
            "image": "./assets/images/splash.png",
            "resizeMode": "cover"
          },
          "android": {
            "backgroundColor": "#3B6FF8",
            "image": "./assets/images/splash.png",
            "resizeMode": "cover"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
